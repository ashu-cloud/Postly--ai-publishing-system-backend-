
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id               String          @id @default(cuid())
  email            String          @unique
  passwordHash     String
  name             String
  bio              String?
  defaultTone      Tone            @default(PROFESSIONAL)
  defaultLanguage  String          @default("en")
  telegramChatId   String?         @unique
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  refreshTokens    RefreshToken[]
  socialAccounts   SocialAccount[]
  aiKeys           AiKeys?
  posts            Post[]

  @@index([email])
}

model RefreshToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())
  revoked   Boolean  @default(false)

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([userId])
}

model SocialAccount {
  id               String   @id @default(cuid())
  userId           String
  platform         Platform
  accessTokenEnc   String
  refreshTokenEnc  String?
  handle           String
  connectedAt      DateTime @default(now())

  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, platform])
  @@index([userId])
}

model AiKeys {
  id               String   @id @default(cuid())
  userId           String   @unique
  openaiKeyEnc     String?
  anthropicKeyEnc  String?
  updatedAt        DateTime @updatedAt

  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Post {
  id            String         @id @default(cuid())
  userId        String
  idea          String
  postType      PostType
  tone          Tone
  language      String         @default("en")
  modelUsed     AiModel
  status        PostStatus     @default(QUEUED)
  publishAt     DateTime?
  deletedAt     DateTime?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  platformPosts PlatformPost[]

  @@index([userId])
  @@index([status])
  @@index([publishAt])
}

model PlatformPost {
  id           String         @id @default(cuid())
  postId       String
  platform     Platform
  content      String
  status       JobStatus      @default(QUEUED)
  publishedAt  DateTime?
  errorMessage String?
  attempts     Int            @default(0)
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  post         Post           @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@index([postId])
  @@index([status])
  @@index([platform])
}

enum Platform {
  TWITTER
  LINKEDIN
  INSTAGRAM
  THREADS
}

enum PostType {
  ANNOUNCEMENT
  THREAD
  STORY
  PROMOTIONAL
  EDUCATIONAL
  OPINION
}

enum Tone {
  PROFESSIONAL
  CASUAL
  WITTY
  AUTHORITATIVE
  FRIENDLY
}

enum AiModel {
  OPENAI
  ANTHROPIC
}

enum PostStatus {
  QUEUED
  PROCESSING
  PARTIAL
  PUBLISHED
  FAILED
  CANCELLED
  SCHEDULED
}

enum JobStatus {
  QUEUED
  PROCESSING
  PUBLISHED
  FAILED
  CANCELLED
}
