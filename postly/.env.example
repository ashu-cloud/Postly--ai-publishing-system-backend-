# ============================================================
# Postly — Environment Variables
# ============================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ============================================================

# ---- Server ------------------------------------------------
PORT=3000
NODE_ENV=development

# ---- Database (PostgreSQL) ---------------------------------
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=postgresql://postly:postly@localhost:5432/postly

# ---- Cache / Queue Backend (Redis) -------------------------
REDIS_URL=redis://localhost:6379

# ---- JWT ---------------------------------------------------
# Use a cryptographically random string of at least 32 characters.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your-super-secret-jwt-key-min-32-chars
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# ---- Encryption (AES-256-GCM) ------------------------------
# MUST be exactly 64 hex characters (32 bytes).
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=your-64-char-hex-encryption-key

# ---- Telegram ----------------------------------------------
# Get your token from @BotFather on Telegram.
TELEGRAM_BOT_TOKEN=your-bot-token-from-botfather

# WEBHOOK_URL is only used in production (NODE_ENV=production).
# Set to your Render/deployed URL (no trailing slash).
WEBHOOK_URL=https://your-app.onrender.com

# ---- AI Keys -----------------------------------------------
# GPT-4o hits OpenAI API directly at api.openai.com.
# DO NOT route this key through OpenRouter.
OPENAI_KEY=your-openai-api-key

# Claude Sonnet 4.6 hits OpenRouter at openrouter.ai.
# This key is ONLY used for Claude — never for GPT-4o.
CLAUDE_API_KEY=your-openrouter-api-key

# ---- Platform API Keys (optional — enables real publishing) -
# Without these, platform services run in demo/simulation mode.
TWITTER_BEARER_TOKEN=
LINKEDIN_ACCESS_TOKEN=
