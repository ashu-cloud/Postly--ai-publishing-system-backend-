{
  "info": {
    "name": "Postly API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "Postly multi-platform AI content publishing backend endpoints."
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3000"
    },
    {
      "key": "accessToken",
      "value": ""
    },
    {
      "key": "refreshToken",
      "value": ""
    },
    {
      "key": "postId",
      "value": ""
    },
    {
      "key": "socialAccountId",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{baseUrl}}/api/auth/register",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"user@example.com\",\n  \"password\": \"password123\",\n  \"name\": \"Demo User\"\n}"
            }
          }
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{baseUrl}}/api/auth/login",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"user@example.com\",\n  \"password\": \"password123\"\n}"
            }
          }
        },
        {
          "name": "Refresh",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{baseUrl}}/api/auth/refresh",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refresh_token\": \"{{refreshToken}}\"\n}"
            }
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{baseUrl}}/api/auth/logout",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refresh_token\": \"{{refreshToken}}\"\n}"
            }
          }
        },
        {
          "name": "Me",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "url": "{{baseUrl}}/api/auth/me"
          }
        }
      ]
    },
    {
      "name": "User",
      "item": [
        {
          "name": "Get Profile",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "url": "{{baseUrl}}/api/user/profile"
          }
        },
        {
          "name": "Update Profile",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{baseUrl}}/api/user/profile",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"bio\": \"Building AI tools\",\n  \"defaultLanguage\": \"en\"\n}"
            }
          }
        },
        {
          "name": "Add Social Account",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{baseUrl}}/api/user/social-accounts",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"platform\": \"TWITTER\",\n  \"accessToken\": \"token-value\",\n  \"handle\": \"postlydemo\"\n}"
            }
          }
        },
        {
          "name": "List Social Accounts",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "url": "{{baseUrl}}/api/user/social-accounts"
          }
        },
        {
          "name": "Delete Social Account",
          "request": {
            "method": "DELETE",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "url": "{{baseUrl}}/api/user/social-accounts/{{socialAccountId}}"
          }
        },
        {
          "name": "Update AI Keys",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{baseUrl}}/api/user/ai-keys",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"openaiKey\": \"sk-your-openai-key\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Content",
      "item": [
        {
          "name": "Generate",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{baseUrl}}/api/content/generate",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"idea\": \"Launching our AI writing assistant next week\",\n  \"postType\": \"ANNOUNCEMENT\",\n  \"platforms\": [\"TWITTER\", \"LINKEDIN\"],\n  \"tone\": \"PROFESSIONAL\",\n  \"language\": \"en\",\n  \"model\": \"openai\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Posts",
      "item": [
        {
          "name": "Publish",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{baseUrl}}/api/posts/publish",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"idea\": \"Launching our AI writing assistant next week\",\n  \"postType\": \"ANNOUNCEMENT\",\n  \"platforms\": [\"TWITTER\", \"LINKEDIN\"],\n  \"tone\": \"PROFESSIONAL\",\n  \"language\": \"en\",\n  \"model\": \"openai\"\n}"
            }
          }
        },
        {
          "name": "Schedule",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{baseUrl}}/api/posts/schedule",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"idea\": \"Launching our AI writing assistant next week\",\n  \"postType\": \"ANNOUNCEMENT\",\n  \"platforms\": [\"TWITTER\", \"LINKEDIN\"],\n  \"tone\": \"PROFESSIONAL\",\n  \"language\": \"en\",\n  \"model\": \"openai\",\n  \"publishAt\": \"2027-01-01T12:00:00.000Z\"\n}"
            }
          }
        },
        {
          "name": "List Posts",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "url": "{{baseUrl}}/api/posts?page=1&limit=10"
          }
        },
        {
          "name": "Get Post",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "url": "{{baseUrl}}/api/posts/{{postId}}"
          }
        },
        {
          "name": "Retry Post",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "url": "{{baseUrl}}/api/posts/{{postId}}/retry"
          }
        },
        {
          "name": "Cancel Scheduled Post",
          "request": {
            "method": "DELETE",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "url": "{{baseUrl}}/api/posts/{{postId}}"
          }
        }
      ]
    },
    {
      "name": "Dashboard",
      "item": [
        {
          "name": "Stats",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "url": "{{baseUrl}}/api/dashboard/stats"
          }
        }
      ]
    },
    {
      "name": "Bot",
      "item": [
        {
          "name": "Webhook",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{baseUrl}}/api/bot/webhook",
            "body": {
              "mode": "raw",
              "raw": "{}"
            }
          }
        }
      ]
    }
  ]
}
